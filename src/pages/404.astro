---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found | GigFlow Pro"
  description="The page you were looking for doesn't exist. Go back to GigFlow Pro."
  canonical="https://www.gigflowpro.com/404"
>
  <div style="background: hsl(220,14%,11%); color: hsl(40,20%,93%); min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem;">
    <p style="font-size: 5rem; font-weight: 800; color: hsl(40,90%,55%); line-height: 1; margin-bottom: 1rem;">404</p>
    <h1 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.75rem;">Page not found</h1>
    <p style="color: hsl(220,10%,55%); margin-bottom: 2rem; max-width: 360px;">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a href="/" style="display: inline-block; background: hsl(40,90%,55%); color: hsl(220,15%,10%); font-weight: 600; padding: 0.75rem 2rem; border-radius: 0.75rem; text-decoration: none;">
      Go to homepage
    </a>
  </div>
</Layout>
