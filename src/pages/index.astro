---
import Layout from '../layouts/Layout.astro';
import LandingDemo from '../components/LandingDemo';
import ContactForm from '../components/ContactForm';

const APP_URL = 'https://app.gigflowpro.com';

const schema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "GigFlow Pro",
  "url": "https://www.gigflowpro.com",
  "description": "Project management software built for freelance photographers. Track bookings, payments, client approvals and automate follow-up reminders — all in one dashboard.",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "featureList": [
    "Project and booking management",
    "Payment and deposit tracking",
    "Client approval links",
    "Automated payment reminders",
    "Status workflow: Booked → Shot → Editing → Delivered → Approved → Paid"
  ],
  "offers": [
    { "@type": "Offer", "name": "Monthly", "price": "29", "priceCurrency": "EUR" },
    { "@type": "Offer", "name": "Annual", "price": "250", "priceCurrency": "EUR" }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do I need a credit card to start the free trial?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. You get 14 days of full access for free. No credit card required until you decide to subscribe."
      }
    },
    {
      "@type": "Question",
      "name": "Is GigFlow Pro only for wedding photographers?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. GigFlow Pro works for any freelance photographer — portraits, events, commercial, headshots, family, newborn, maternity, and more."
      }
    },
    {
      "@type": "Question",
      "name": "Can I cancel at any time?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Cancel anytime from your account settings. No lock-in, no cancellation fees."
      }
    },
    {
      "@type": "Question",
      "name": "What happens to my projects if I cancel?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your data stays accessible until the end of your billing period. You can export or import your project information at any time from Settings → Data & Backup."
      }
    }
  ]
};
---

<Layout
  title="GigFlow Pro — Project Management for Freelance Photographers"
  description="Stop losing money to missed follow-ups. GigFlow Pro covers your entire workflow from booking to final payment — in one clean dashboard."
  ogImage="https://www.gigflowpro.com/screenshots/Dashboard1.png"
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b" style="background: rgba(14,16,23,0.90); backdrop-filter: blur(12px); border-color: hsl(220,10%,22%)">
    <div class="max-w-6xl mx-auto flex items-center justify-between px-6 h-16">
      <div class="flex items-center gap-2.5">
        <img src="/favicon-32x32.png" alt="GigFlow Pro" class="h-8 w-8 rounded-lg object-cover" />
        <span class="font-semibold tracking-tight">GigFlow Pro</span>
      </div>
      <div class="flex items-center gap-3">
        <a href={`${APP_URL}/login`} class="px-4 py-2 text-sm font-medium transition-colors rounded-lg" style="color: hsl(220,10%,60%); hover:color: hsl(40,20%,93%)">Log In</a>
        <a href={`${APP_URL}/signup`} class="px-4 py-2 text-sm font-semibold rounded-lg transition-colors" style="background: hsl(40,90%,55%); color: hsl(220,15%,10%)">Get Started</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="pt-32 pb-20 px-6">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-6" style="animation: fade-in 0.4s ease-out">
        <div class="inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-medium border" style="background: hsl(40,90%,55%,0.12); color: hsl(40,90%,65%); border-color: hsl(40,90%,55%,0.25)">
          ★ Built for freelance photographers
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1]">
          Stop losing money to missed follow-ups
        </h1>
        <p class="text-lg max-w-lg leading-relaxed" style="color: hsl(220,10%,58%)">
          Track every project, nudge every client, and see exactly what's outstanding — from first booking to final payment.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href={`${APP_URL}/signup`} class="inline-flex items-center justify-center gap-2 h-12 px-8 rounded-xl text-base font-semibold transition-colors" style="background: hsl(40,90%,55%); color: hsl(220,15%,10%)">
            Start Free Trial →
          </a>
          <a href="#features" class="inline-flex items-center justify-center h-12 px-8 rounded-xl text-base font-medium border transition-colors hover:bg-white/[0.06]" style="border-color: hsl(220,10%,28%); color: hsl(40,20%,85%)">
            See How It Works
          </a>
        </div>
        <p class="text-xs" style="color: hsl(220,10%,50%)">€29/month · Cancel anytime · 14-day free trial · No card required</p>
      </div>
      <div style="animation: fade-in 0.4s ease-out 0.2s both">
        <div class="rounded-2xl overflow-hidden border shadow-2xl" style="border-color: hsl(220,10%,22%); box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5)">
          <div class="flex items-center gap-1.5 px-4 py-2.5 border-b" style="background: hsl(220,14%,16%); border-color: hsl(220,10%,22%)">
            <div class="h-2 w-2 rounded-full bg-red-400/60"></div>
            <div class="h-2 w-2 rounded-full bg-yellow-400/60"></div>
            <div class="h-2 w-2 rounded-full bg-green-400/60"></div>
            <span class="mx-auto text-[10px]" style="color: hsl(220,10%,48%)">gigflowpro.com/dashboard</span>
          </div>
          <img src="/screenshots/Dashboard1.png" alt="GigFlow Pro Dashboard — project management for photographers" class="w-full h-auto" />
        </div>
        <div class="mt-[-1.5rem] ml-[-1rem] inline-flex items-center gap-3 rounded-xl border p-4 shadow-lg" style="background: hsl(220,14%,13%); border-color: hsl(220,10%,22%)">
          <div class="h-10 w-10 rounded-full flex items-center justify-center" style="background: hsl(152,60%,42%,0.2)">
            <span style="color: hsl(152,60%,50%)">✓</span>
          </div>
          <div>
            <p class="text-xs font-medium">Client Approved</p>
            <p class="text-xs" style="color: hsl(220,10%,58%)">Emma & James — Wedding</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pain points -->
  <section class="py-16 px-6 border-t" style="border-color: hsl(220,10%,22%)">
    <div class="max-w-5xl mx-auto space-y-10">
      <div class="text-center space-y-3">
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">Sound familiar?</h2>
        <p class="text-base max-w-xl mx-auto" style="color: hsl(220,10%,58%)">
          Most photographers don't lose work — they lose control of it.
        </p>
      </div>
      <div class="grid sm:grid-cols-3 gap-6">
        <div class="rounded-2xl border p-6 space-y-3" style="background: hsl(220,14%,12%); border-color: hsl(220,10%,22%)">
          <div class="text-2xl">👻</div>
          <h3 class="font-semibold text-base">Leads go quiet after the call</h3>
          <p class="text-sm leading-relaxed" style="color: hsl(220,10%,55%)">You send a quote and hear nothing. No system to track who needs a nudge, and when.</p>
        </div>
        <div class="rounded-2xl border p-6 space-y-3" style="background: hsl(220,14%,12%); border-color: hsl(220,10%,22%)">
          <div class="text-2xl">💸</div>
          <h3 class="font-semibold text-base">Deposits and payments drag on</h3>
          <p class="text-sm leading-relaxed" style="color: hsl(220,10%,55%)">Balances stay unpaid. Clients forget. You spend time chasing instead of shooting.</p>
        </div>
        <div class="rounded-2xl border p-6 space-y-3" style="background: hsl(220,14%,12%); border-color: hsl(220,10%,22%)">
          <div class="text-2xl">📋</div>
          <h3 class="font-semibold text-base">No clear view of what's outstanding</h3>
          <p class="text-sm leading-relaxed" style="color: hsl(220,10%,55%)">Ten active projects. Which ones are waiting on the client? Which are overdue? Hard to say.</p>
        </div>
      </div>
      <p class="text-center text-base max-w-2xl mx-auto pt-2" style="color: hsl(220,10%,62%)">
        GigFlow Pro handles the follow-up, tracks the money, and keeps every project visible — so you spend your time shooting, not chasing.
      </p>
    </div>
  </section>

  <!-- Status flow -->
  <section class="py-16 px-6 border-y" style="background: hsl(220,14%,12%); border-color: hsl(220,10%,22%)">
    <div class="max-w-4xl mx-auto text-center space-y-8">
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">
        A status flow that mirrors how you actually work
      </h2>
      <div class="flex items-center justify-center gap-2 flex-wrap">
        {[
          { label: 'Booked', color: 'hsl(210,80%,60%)' },
          { label: 'Shot', color: 'hsl(40,90%,60%)' },
          { label: 'Editing', color: 'hsl(38,92%,55%)' },
          { label: 'Delivered', color: 'hsl(220,10%,65%)' },
          { label: 'Approved', color: 'hsl(152,60%,50%)' },
          { label: 'Paid', color: 'hsl(152,60%,50%)' },
        ].map((step, i, arr) => (
          <div class="flex items-center gap-2">
            <div class="flex items-center gap-2 rounded-full border px-4 py-2" style={`border-color: ${step.color}40; background: ${step.color}18`}>
              <div class="h-2 w-2 rounded-full" style={`background: ${step.color}`}></div>
              <span class="text-sm font-medium" style={`color: ${step.color}`}>{step.label}</span>
            </div>
            {i < arr.length - 1 && <span class="hidden sm:block" style="color: hsl(220,10%,35%)">→</span>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features (interactive demo) -->
  <section id="features" class="py-20 px-6 border-t" style="border-color: hsl(220,10%,22%)">
    <div class="max-w-6xl mx-auto space-y-10">
      <div class="text-center space-y-3">
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">See it in action</h2>
        <p style="color: hsl(220,10%,58%)">From first booking to final payment.</p>
      </div>
      <LandingDemo client:load />
    </div>
  </section>

  <!-- USP proof -->
  <section class="py-20 px-6 border-t" style="border-color: hsl(220,10%,22%)">
    <div class="max-w-5xl mx-auto space-y-12">
      <div class="text-center space-y-3">
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">How GigFlow Pro fixes it</h2>
        <p style="color: hsl(220,10%,58%)">Each feature is built around a real problem photographers run into every week.</p>
      </div>
      <div class="grid sm:grid-cols-3 gap-8">
        <div class="space-y-3">
          <div class="text-xs font-semibold uppercase tracking-widest" style="color: hsl(40,90%,55%)">Deposits & payments</div>
          <h3 class="font-semibold text-base leading-snug">Reminders go out automatically — you don't have to remember</h3>
          <p class="text-sm leading-relaxed" style="color: hsl(220,10%,55%)">Set your deposit rules once. GigFlow Pro sends reminders to clients at 14, 7, and 3 days before the shoot — and again when the final balance is due.</p>
        </div>
        <div class="space-y-3">
          <div class="text-xs font-semibold uppercase tracking-widest" style="color: hsl(40,90%,55%)">Client approvals</div>
          <h3 class="font-semibold text-base leading-snug">Clients approve with one link — no back-and-forth emails</h3>
          <p class="text-sm leading-relaxed" style="color: hsl(220,10%,55%)">Send your client a personalised approval link. They review the delivery, mark favourites, and approve or request changes — all in one place, attached to the project.</p>
        </div>
        <div class="space-y-3">
          <div class="text-xs font-semibold uppercase tracking-widest" style="color: hsl(40,90%,55%)">Pipeline visibility</div>
          <h3 class="font-semibold text-base leading-snug">Know exactly where every project stands at a glance</h3>
          <p class="text-sm leading-relaxed" style="color: hsl(220,10%,55%)">Every project moves through a clear status — Booked, Shot, Editing, Delivered, Approved, Paid. Open the dashboard and see instantly what needs your attention.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-20 px-6 border-t" style="background: hsl(220,14%,12%); border-color: hsl(220,10%,22%)">
    <div class="max-w-md mx-auto text-center space-y-6">
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">One plan. Everything included.</h2>
      <div class="rounded-2xl border p-8 space-y-4 shadow-sm" style="background: hsl(220,14%,13%); border-color: hsl(220,10%,22%)">
        <p class="text-sm" style="color: hsl(220,10%,58%)">Everything included</p>
        <div class="flex items-baseline justify-center gap-1">
          <span class="text-4xl font-bold font-sans">€29</span>
          <span style="color: hsl(220,10%,58%)">/month</span>
        </div>
        <p class="text-xs" style="color: hsl(220,10%,50%)">or €250/year (save €98)</p>
        <a href={`${APP_URL}/signup`} class="block w-full h-12 leading-[3rem] rounded-xl text-base font-semibold transition-colors" style="background: hsl(40,90%,55%); color: hsl(220,15%,10%)">
          Start 14-Day Free Trial
        </a>
        <p class="text-xs" style="color: hsl(220,10%,50%)">No card required · Cancel anytime · Early access members lock in this price forever.</p>
        <ul class="grid grid-cols-2 gap-2 pt-2 text-left">
          {['Unlimited projects', 'Client approval links', 'Payment tracking', 'Auto reminders', 'Status workflow', 'Cancel anytime'].map(f => (
            <li class="flex items-center gap-2 text-sm" style="color: hsl(220,10%,60%)">
              <span style="color: hsl(152,60%,50%)">✓</span> {f}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 px-6 border-t" style="border-color: hsl(220,10%,22%)">
    <div class="max-w-2xl mx-auto space-y-8">
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-center">Common questions</h2>
      <dl class="space-y-6">
        {[
          {
            q: 'Do I need a credit card to start the free trial?',
            a: 'No. You get 14 days of full access for free. No credit card required until you decide to subscribe.',
          },
          {
            q: 'Is GigFlow Pro only for wedding photographers?',
            a: 'No. It works for any freelance photographer — portraits, events, commercial, headshots, family, newborn, maternity, and more.',
          },
          {
            q: 'Can I cancel at any time?',
            a: 'Yes. Cancel anytime from your account settings. No lock-in, no cancellation fees.',
          },
          {
            q: 'What happens to my projects if I cancel?',
            a: 'Your data stays accessible until the end of your billing period. You can export or import your project information at any time from Settings → Data & Backup.',
          },
        ].map(({ q, a }) => (
          <div class="rounded-xl border p-6 space-y-2" style="background: hsl(220,14%,12%); border-color: hsl(220,10%,22%)">
            <dt class="font-semibold text-base">{q}</dt>
            <dd class="text-sm leading-relaxed" style="color: hsl(220,10%,58%)">{a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Contact -->
  <section class="py-20 px-6 border-t" style="border-color: hsl(220,10%,22%)">
    <div class="max-w-md mx-auto text-center space-y-6">
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">Get in touch</h2>
      <p class="text-sm" style="color: hsl(220,10%,58%)">Questions before signing up? We'll get back to you within 24 hours.</p>
      <ContactForm client:load />
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-8 px-6 border-t" style="border-color: hsl(220,10%,22%)">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <img src="/favicon-32x32.png" alt="GigFlow Pro" class="h-6 w-6 rounded-md object-cover" />
        <span class="text-sm" style="color: hsl(220,10%,50%)">GigFlow Pro</span>
      </div>
      <div class="flex flex-wrap justify-center gap-4 text-xs" style="color: hsl(220,10%,50%)">
        <a href="https://app.gigflowpro.com/terms" class="hover:text-white transition-colors">Terms of Service</a>
        <a href="https://app.gigflowpro.com/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="https://app.gigflowpro.com/refunds" class="hover:text-white transition-colors">Refund Policy</a>
        <a href="https://app.gigflowpro.com/cookies" class="hover:text-white transition-colors">Cookie Policy</a>
        <a href="/blog" class="hover:text-white transition-colors">Blog</a>
      </div>
      <p class="text-xs" style="color: hsl(220,10%,50%)">© 2026 Norda Solutions</p>
    </div>
  </footer>
</Layout>
