---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<Layout
  title="Blog — GigFlow Pro"
  description="Tips on workflow, client management, and growing your freelance photography business."
>
  <div style="background: hsl(40,20%,98%); color: hsl(220,15%,13%); min-height: 100vh">
    <nav class="fixed top-0 left-0 right-0 z-50 border-b" style="background: rgba(253,251,247,0.92); backdrop-filter: blur(12px); border-color: hsl(220,10%,90%)">
      <div class="max-w-6xl mx-auto flex items-center justify-between px-6 h-16">
        <a href="/" class="flex items-center gap-2.5">
          <img src="/favicon-32x32.png" alt="GigFlow Pro" class="h-8 w-8 rounded-lg object-cover" />
          <span class="font-semibold tracking-tight" style="color: hsl(220,15%,13%)">GigFlow Pro</span>
        </a>
        <div class="flex items-center gap-3">
          <a href="https://app.gigflowpro.com/login" class="px-4 py-2 text-sm font-medium transition-colors rounded-lg" style="color: hsl(220,10%,40%)">Log In</a>
          <a href="https://app.gigflowpro.com/signup" class="px-4 py-2 text-sm font-semibold rounded-lg transition-colors" style="background: hsl(40,90%,55%); color: hsl(220,15%,10%)">Get Started</a>
        </div>
      </div>
    </nav>

    <main class="pt-28 pb-20 px-6">
      <div class="max-w-3xl mx-auto space-y-12">
        <div class="space-y-2">
          <h1 class="text-4xl font-bold tracking-tight" style="color: hsl(220,15%,13%)">Blog</h1>
          <p style="color: hsl(220,10%,50%)">Resources for freelance photographers</p>
        </div>

        {posts.length === 0 && (
          <p style="color: hsl(220,10%,50%)">No posts yet — check back soon.</p>
        )}

        <div class="space-y-8">
          {posts.map(post => (
            <article class="border-b pb-8" style="border-color: hsl(220,10%,88%)">
              <a href={`/blog/${post.id}`} class="group block space-y-3">
                <div class="flex items-center gap-2 text-xs" style="color: hsl(220,10%,50%)">
                  <time datetime={post.data.publishDate.toISOString()}>
                    {post.data.publishDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </time>
                  {post.data.tags.slice(0, 2).map(tag => (
                    <span class="rounded-full px-2 py-0.5 text-xs" style="background: hsl(40,90%,55%,0.1); color: hsl(40,70%,35%)">{tag}</span>
                  ))}
                </div>
                <h2 class="text-xl font-bold tracking-tight group-hover:underline decoration-1 underline-offset-2" style="color: hsl(220,15%,13%)">{post.data.title}</h2>
                <p style="color: hsl(220,10%,45%)">{post.data.description}</p>
                <span class="text-sm font-medium" style="color: hsl(40,70%,35%)">Read more →</span>
              </a>
            </article>
          ))}
        </div>
      </div>
    </main>

    <footer class="py-8 px-6 border-t" style="border-color: hsl(220,10%,88%)">
      <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-2">
          <img src="/favicon-32x32.png" alt="GigFlow Pro" class="h-6 w-6 rounded-md object-cover" />
          <span class="text-sm" style="color: hsl(220,10%,50%)">GigFlow Pro</span>
        </a>
        <p class="text-xs" style="color: hsl(220,10%,50%)">© 2026 Norda Solutions</p>
      </div>
    </footer>
  </div>
</Layout>
