---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const relatedPosts = (await getCollection('blog'))
  .filter(p => p.id !== post.id)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 2);

const canonicalUrl = `https://www.gigflowpro.com/blog/${post.id}`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "url": canonicalUrl,
  "datePublished": post.data.publishDate.toISOString(),
  "author": {
    "@type": "Organization",
    "name": "GigFlow Pro",
    "url": "https://www.gigflowpro.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "GigFlow Pro",
    "url": "https://www.gigflowpro.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://www.gigflowpro.com/favicon-32x32.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  },
  ...(post.data.ogImage ? { "image": post.data.ogImage } : {})
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.gigflowpro.com" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://www.gigflowpro.com/blog" },
    { "@type": "ListItem", "position": 3, "name": post.data.title, "item": canonicalUrl }
  ]
};
---

<Layout
  title={`${post.data.title} — GigFlow Pro Blog`}
  description={post.data.description}
  canonical={canonicalUrl}
  ogImage={post.data.ogImage}
  ogType="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <div style="background: hsl(40,20%,98%); color: hsl(220,15%,13%); min-height: 100vh">
    <nav class="fixed top-0 left-0 right-0 z-50 border-b" style="background: rgba(253,251,247,0.92); backdrop-filter: blur(12px); border-color: hsl(220,10%,90%)">
      <div class="max-w-6xl mx-auto flex items-center justify-between px-6 h-16">
        <a href="/" class="flex items-center gap-2.5">
          <img src="/favicon-32x32.png" alt="GigFlow Pro" class="h-8 w-8 rounded-lg object-cover" />
          <span class="font-semibold tracking-tight" style="color: hsl(220,15%,13%)">GigFlow Pro</span>
        </a>
        <div class="flex items-center gap-3">
          <a href="https://app.gigflowpro.com/login" class="px-4 py-2 text-sm font-medium transition-colors rounded-lg" style="color: hsl(220,10%,40%)">Log In</a>
          <a href="https://app.gigflowpro.com/signup" class="px-4 py-2 text-sm font-semibold rounded-lg transition-colors" style="background: hsl(40,90%,55%); color: hsl(220,15%,10%)">Get Started</a>
        </div>
      </div>
    </nav>

    <main class="pt-28 pb-20 px-6">
      <div class="max-w-2xl mx-auto">
        <div class="mb-8 space-y-4">
          <a href="/blog" class="text-sm" style="color: hsl(220,10%,50%)">← Back to blog</a>
          <div class="flex items-center gap-2 text-xs" style="color: hsl(220,10%,50%)">
            <time datetime={post.data.publishDate.toISOString()}>
              {post.data.publishDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
            </time>
            <span>·</span>
            <span>{post.data.author}</span>
            {post.data.tags.slice(0, 3).map(tag => (
              <span class="rounded-full px-2 py-0.5" style="background: hsl(40,90%,55%,0.1); color: hsl(40,70%,35%)">{tag}</span>
            ))}
          </div>
          <h1 class="text-3xl sm:text-4xl font-bold tracking-tight leading-tight" style="color: hsl(220,15%,13%)">{post.data.title}</h1>
          <p class="text-lg" style="color: hsl(220,10%,45%)">{post.data.description}</p>
        </div>

        <article class="prose prose-gray max-w-none prose-headings:font-semibold prose-a:text-amber-600 prose-a:no-underline hover:prose-a:underline prose-h1:hidden" style="color: hsl(220,15%,20%)">
          <Content />
        </article>

        <!-- Related posts -->
        {relatedPosts.length > 0 && (
          <div class="mt-16 space-y-4">
            <h2 class="text-lg font-semibold" style="color: hsl(220,15%,13%)">More from the blog</h2>
            <div class="grid sm:grid-cols-2 gap-4">
              {relatedPosts.map(p => (
                <a href={`/blog/${p.id}`} class="block rounded-2xl border p-5 space-y-2 hover:border-amber-300 transition-colors" style="background: hsl(220,10%,97%); border-color: hsl(220,10%,88%)">
                  <p class="text-xs" style="color: hsl(220,10%,50%)">{p.data.publishDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
                  <p class="font-semibold text-sm leading-snug" style="color: hsl(220,15%,13%)">{p.data.title}</p>
                  <p class="text-xs leading-relaxed" style="color: hsl(220,10%,50%)">{p.data.description}</p>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- CTA -->
        <div class="mt-16 rounded-2xl border p-8 text-center space-y-4" style="background: hsl(220,10%,95%); border-color: hsl(220,10%,88%)">
          <h2 class="text-xl font-bold" style="color: hsl(220,15%,13%)">Ready to simplify your photography business?</h2>
          <p class="text-sm" style="color: hsl(220,10%,50%)">Join photographers already using GigFlow Pro to stay organised and get paid faster.</p>
          <a href="https://app.gigflowpro.com/signup" class="inline-block px-8 py-3 rounded-xl font-semibold transition-colors" style="background: hsl(220,15%,13%); color: hsl(40,20%,98%)">
            Start Free Trial — 14 days free
          </a>
        </div>
      </div>
    </main>

    <footer class="py-8 px-6 border-t" style="border-color: hsl(220,10%,88%)">
      <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-2">
          <img src="/favicon-32x32.png" alt="GigFlow Pro" class="h-6 w-6 rounded-md object-cover" />
          <span class="text-sm" style="color: hsl(220,10%,50%)">GigFlow Pro</span>
        </a>
        <div class="flex items-center gap-4">
          <a href="https://www.instagram.com/gigflowpro/" rel="noopener noreferrer" target="_blank" aria-label="GigFlow Pro on Instagram" style="color: hsl(220,10%,50%)" class="hover:text-foreground transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
          <a href="https://www.linkedin.com/showcase/gigflow-pro/about/" rel="noopener noreferrer" target="_blank" aria-label="GigFlow Pro on LinkedIn" style="color: hsl(220,10%,50%)" class="hover:text-foreground transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <p class="text-xs" style="color: hsl(220,10%,50%)">© 2026 Norda Solutions</p>
        </div>
      </div>
    </footer>
  </div>
</Layout>
