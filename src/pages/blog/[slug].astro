---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout
  title={`${post.data.title} — GigFlow Pro Blog`}
  description={post.data.description}
  ogImage={post.data.ogImage}
>
  <nav class="fixed top-0 left-0 right-0 z-50 border-b" style="background: rgba(253,251,247,0.85); backdrop-filter: blur(12px); border-color: hsl(220,10%,90%)">
    <div class="max-w-6xl mx-auto flex items-center justify-between px-6 h-16">
      <a href="/" class="flex items-center gap-2.5">
        <img src="/favicon-32x32.png" alt="GigFlow Pro" class="h-8 w-8 rounded-lg object-cover" />
        <span class="font-semibold tracking-tight">GigFlow Pro</span>
      </a>
      <div class="flex items-center gap-3">
        <a href="https://app.gigflowpro.com/login" class="px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors rounded-lg hover:bg-gray-100">Log In</a>
        <a href="https://app.gigflowpro.com/signup" class="px-4 py-2 text-sm font-semibold rounded-lg transition-colors" style="background: hsl(40,90%,55%); color: hsl(220,15%,10%)">Get Started</a>
      </div>
    </div>
  </nav>

  <main class="pt-28 pb-20 px-6">
    <div class="max-w-2xl mx-auto">
      <div class="mb-8 space-y-4">
        <a href="/blog" class="text-sm" style="color: hsl(220,10%,50%)">← Back to blog</a>
        <div class="flex items-center gap-2 text-xs" style="color: hsl(220,10%,50%)">
          <time datetime={post.data.publishDate.toISOString()}>
            {post.data.publishDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
          </time>
          <span>·</span>
          <span>{post.data.author}</span>
          {post.data.tags.slice(0, 3).map(tag => (
            <span class="rounded-full px-2 py-0.5" style="background: hsl(40,90%,55%,0.1); color: hsl(40,90%,40%)">{tag}</span>
          ))}
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight leading-tight">{post.data.title}</h1>
        <p class="text-lg" style="color: hsl(220,10%,50%)">{post.data.description}</p>
      </div>

      <article class="prose prose-gray max-w-none prose-headings:font-display prose-a:text-amber-600 prose-a:no-underline hover:prose-a:underline prose-h1:hidden">
        <Content />
      </article>

      <!-- CTA -->
      <div class="mt-16 rounded-2xl border p-8 text-center space-y-4" style="background: hsl(220,10%,97%); border-color: hsl(220,10%,90%)">
        <h2 class="text-xl font-bold">Ready to simplify your photography business?</h2>
        <p class="text-sm" style="color: hsl(220,10%,50%)">Join photographers already using GigFlow Pro to stay organised and get paid faster.</p>
        <a href="https://app.gigflowpro.com/signup" class="inline-block px-8 py-3 rounded-xl font-semibold transition-colors" style="background: hsl(220,15%,13%); color: hsl(40,20%,98%)">
          Start Free Trial — 14 days free
        </a>
      </div>
    </div>
  </main>

  <footer class="py-8 px-6 border-t" style="border-color: hsl(220,10%,90%)">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-2">
        <img src="/favicon-32x32.png" alt="GigFlow Pro" class="h-6 w-6 rounded-md object-cover" />
        <span class="text-sm" style="color: hsl(220,10%,50%)">GigFlow Pro</span>
      </a>
      <p class="text-xs" style="color: hsl(220,10%,50%)">© 2026 Norda Solutions</p>
    </div>
  </footer>
</Layout>
