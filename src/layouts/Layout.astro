---
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description = 'Project management software built for freelance photographers. Track bookings, payments, client approvals and automate follow-up reminders — all in one dashboard.',
  canonical = Astro.url.href,
  ogImage,
  ogType = 'website',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="GigFlow Pro" />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Analytics loaded only after cookie consent (see CookieBanner component) -->
    <script>
      if (typeof localStorage !== 'undefined' && localStorage.getItem('cookie_consent') === 'accepted') {
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-L2KN5H42NG';
        s.async = true;
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-L2KN5H42NG');
        window.gtag = gtag;
        window.__gaLoaded = true;
      }
    </script>
  </head>
  <body>
    <slot />
    <CookieBanner client:load />
  </body>
</html>
